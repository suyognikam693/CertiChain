# Backend environment example for CertiChain

# Blockchain
ETHERSCAN_API_KEY=your_etherscan_api_key
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key
HARDHAT_NODE_URL=http://localhost:8545
CONTRACT_ADDRESS=0xYourDeployedContractAddress
UNIVERSITY_ADDRESS=0xYourDeployerAddress
UNIVERSITY_PRIVATE_KEY=0xYourPrivateKey

# IPFS Cluster and Kubo
CLUSTER_API_URL=http://localhost:9094
CLUSTER_GATEWAY_URLS=http://localhost:8080,http://localhost:8082
IPFS_API_URLS=http://localhost:5001,http://localhost:5003

# App
API_KEY=replace-with-a-random-secret
FRONTEND_URL=http://localhost:3000
